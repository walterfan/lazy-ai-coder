# Database Configuration
DB_USER=postgres
DB_PASS=your_secure_db_password
DB_NAME=lazy_ai_coder
DB_URL=postgres://postgres:your_secure_db_password@pgvector:5432/lazy_ai_coder?sslmode=disable

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password

# JupyterLab Configuration
JUPYTER_PASSWORD=your_secure_jupyter_password

# LLM Configuration
LLM_API_KEY=sk-your-llm-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# GitLab Configuration
GITLAB_TOKEN=glpat-your-gitlab-token
GITLAB_BASE_URL=https://gitlab.com

# PlantUML Configuration
PLANTUML_URL=http://plantuml:8080
PLANTUML_PUBLIC_URL=http://localhost:8000

# Admin Configuration (optional)
#ADMIN_USERNAME=admin
#ADMIN_PASSWORD=your_admin_password

# Go Proxy (optional, for faster builds in China)
#GOPROXY=https://goproxy.cn,direct
